{
  "title": "NanoTDB Dashboard",
  "default_db": "metrics",
  "groups": [
    {
      "id": "overview",
      "label": "Overview",
      "widgets": ["system_snapshot", "cpu_busy_aggregate", "storage_snapshot", "system_history"]
    },
    {
      "id": "events",
      "label": "Events",
      "widgets": ["slow_writes", "internal_events_feed"]
    }
  ],
  "widgets": {
    "system_snapshot": {
      "type": "numbers",
      "title": "System Snapshot",
      "refresh_sec": 10,
      "series": [
        {
          "label": "Load 1m",
          "metric": "sys.load1",
          "transform": { "decimals": 2 }
        },
        {
          "label": "Load 5m",
          "metric": "sys.load5",
          "transform": { "decimals": 2 }
        },
        {
          "label": "Mem Avail",
          "metric": "mem.available",
          "transform": { "factor": 0.000001, "unit": " GB", "decimals": 1 },
          "thresholds": { "direction": "below", "warning": 1.0, "critical": 0.5 }
        },
        {
          "label": "CPU Clock",
          "metric": "cpu.freq_khz",
          "transform": { "factor": 0.000001, "unit": " GHz", "decimals": 2 }
        },
        {
          "label": "CPU Temp",
          "metric": "temp.cpu",
          "transform": { "factor": 0.001, "unit": " C", "decimals": 1 },
          "thresholds": { "direction": "above", "warning": 70, "critical": 80 }
        }
      ]
    },
    "cpu_busy_aggregate": {
      "type": "aggregate_band",
      "title": "CPU Busy",
      "refresh_sec": 15,
      "lookback": "24h",
      "interval": "10m",
      "series": [
        {
          "metric": "cpu.busy_pct",
          "window": "10m",
          "transform": { "unit": "%", "decimals": 1 }
        }
      ]
    },
    "storage_snapshot": {
      "type": "numbers",
      "title": "Storage Snapshot",
      "refresh_sec": 15,
      "series": [
        {
          "label": "Root Used %",
          "metric": "diskfs.root.used_pct",
          "transform": { "unit": "%", "decimals": 1 },
          "thresholds": { "direction": "above", "warning": 80, "critical": 90 }
        },
        {
          "label": "Root Free",
          "metric": "diskfs.root.bytes_avail",
          "transform": { "factor": 0.0000000009313225746154785, "unit": " GiB", "decimals": 1 },
          "thresholds": { "direction": "below", "warning": 8, "critical": 4 }
        },
        {
          "label": "SD Write ms",
          "metric": "disk.sd_write_probe_ms",
          "transform": { "unit": " ms", "decimals": 1 },
          "thresholds": { "direction": "above", "warning": 25, "critical": 50 }
        }
      ]
    },
    "system_history": {
      "type": "line_chart",
      "title": "System Activity",
      "refresh_sec": 30,
      "lookback": "6h",
      "interval": "1m",
      "series": [
        {
          "label": "CPU Busy",
          "metric": "cpu.busy_pct",
          "aggregate": "avg",
          "window": "1m",
          "transform": { "unit": "%", "decimals": 1 }
        },
        {
          "label": "SD Write ms",
          "metric": "disk.sd_write_probe_ms",
          "aggregate": "avg",
          "window": "1m",
          "transform": { "unit": " ms", "decimals": 1 }
        }
      ],
      "event_overlays": [
        {
          "label": "Engine start",
          "event_name_pattern": "nanotdb.engine.started",
          "db": "internal",
          "color": "#0a7",
          "event_limit": 20
        },
        {
          "label": "Slow SD write",
          "event_name_pattern": "drip.threshold.disk.sd_write_probe.slow",
          "db": "internal",
          "color": "#c33",
          "event_limit": 50
        }
      ]
    },
    "slow_writes": {
      "type": "event_log",
      "title": "Slow Disk Writes",
      "refresh_sec": 10,
      "lookback": "6h",
      "series": [
        {
          "event_name_pattern": "drip.threshold.disk.sd_write_probe.slow",
          "event_limit": 10,
          "db": "internal"
        },
        {
          "event_name_pattern": "disk.sd_write_probe.slow",
          "event_limit": 10,
          "db": "metrics"
        }
      ]
    },
    "internal_events_feed": {
      "type": "event_log",
      "title": "Engine Events",
      "refresh_sec": 10,
      "lookback": "1h",
      "series": [
        {
          "event_name_pattern": "nanotdb.*",
          "event_limit": 30,
          "db": "internal"
        },
        {
          "event_name_pattern": "drip.*",
          "event_limit": 20,
          "db": "internal"
        }
      ]
    }
  }
}